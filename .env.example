# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/
MONGODB_DB=wingo
MONGODB_COLLECTION=results

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_URL=http://api:5000

# Dashboard Configuration
DASHBOARD_TIMEOUT=5

# Trainer Configuration
MODEL_PATH=models/model.pkl
TRAINER_SLEEP_INTERVAL=120
MIN_TRAINING_SAMPLES=30
MIN_DATA_AFTER_SHIFT=10
SEQUENCE_LENGTH=10

# Scraper Configuration (REAL MODE)
SCRAPER_MODE=real
SCRAPER_INTERVAL=30
SCRAPER_TIMEOUT=25
MAX_RETRIES=3
RETRY_BACKOFF=5

# Scraper Configuration (SIMULATION MODE - legacy)
SCRAPER_SLEEP_INTERVAL=60
RANDOM_NUMBER_MIN=0
RANDOM_NUMBER_MAX=9
